{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM"]
  },
  "include": ["src/**/*", "remotion/**/*", "web/src/**/*", "web/tests/**/*", "web/next.config.ts"],
  "exclude": [
    "node_modules",
    "web/src/fonts.ts",
    "web/src/app/**",
    "web/src/theme/index.ts",
    "web/instrumentation.ts",
    "web/src/lib/cacheSchema.ts",
    "web/src/lib/cache.ts",
    "web/src/lib/cacheInvalidation.ts",
    "web/src/lib/cache.test.ts",
    "web/src/lib/cacheInvalidation.test.ts",
    "web/tests/cache.bench.ts",
    "web/src/lib/discoveryRuntime.ts",
    "web/src/lib/discoveryRuntime.test.ts"
  ]
}
