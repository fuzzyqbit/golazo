{
  "name": "@golazo/cli",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["web"],
  "description": "Local-Mac CLI: clip folder → branded YouTube episode",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.0",
  "bin": {
    "golazo": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "web:dev": "npm run dev --workspace=@golazo/web",
    "web:build": "npm run build --workspace=@golazo/web",
    "web:start": "npm run start --workspace=@golazo/web"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.461",
    "@remotion/cli": "^4.0.461",
    "@remotion/fonts": "^4.0.461",
    "@remotion/renderer": "^4.0.461",
    "commander": "^14.0.0",
    "googleapis": "^144.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remotion": "^4.0.461",
    "yaml": "^2.9.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.3.0",
    "nock": "^14.0.15",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
