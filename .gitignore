.superpowers/
node_modules/
dist/
coverage/
.golazo/
*.token.json
channels.yaml
.DS_Store
*.log
.env*
tests/fixtures/*.mp4
# npm puts its log + update-notifier cache here when HOME is stubbed to
# the repo root (see tests/fixtures/golazo/README.md — vitest / manual
# CLI smokes use HOME="$PWD"). Not a build artifact; safe to ignore.
.npm/

# Allow committed integration-fixture binaries — see
# tests/fixtures/golazo/README.md and scripts/build-fixtures.sh. The
# broad rules above cover operator-side generated artifacts; these `!`
# exceptions whitelist the version-controlled fixture assets so they
# survive `git add`. The fixture's channels.yaml is also whitelisted
# because the broad `channels.yaml` rule above is aimed at the operator's
# real config at the repo root.
!tests/fixtures/golazo/channels.yaml
!tests/fixtures/golazo/leo/2026-05-13_vs_united_3-1/*.mp4
!tests/fixtures/golazo/*.token.json

# Allow committed Remotion font assets — see remotion/assets/fonts/README.md
!remotion/assets/fonts/*.ttf

# Allow committed Remotion music fixtures — see remotion/assets/music/README.md
# (Plan 02-02 commits the .mp3 pool + index.json under remotion/assets/music/)
!remotion/assets/music/*.mp3
!remotion/assets/music/index.json

# Snapshot diff outputs are debug artifacts only — never committed
tests/snapshots/.diff/

# Allow committed web fixture tree — see web/tests/fixtures/golazo/README.md.
# The broad rules above (tests/fixtures/*.mp4, .golazo/, channels.yaml) need
# explicit allow-lines for the per-game artifacts the scanner walks.
!web/tests/fixtures/golazo/channels.yaml
!web/tests/fixtures/golazo/**/*.mp4
!web/tests/fixtures/golazo/**/*.png
!web/tests/fixtures/golazo/**/.golazo/
!web/tests/fixtures/golazo/**/.golazo/manifest.json
!web/tests/fixtures/golazo/**/.golazo/episode.mp4
!web/tests/fixtures/golazo/**/.golazo/thumb.png
!web/tests/fixtures/golazo/**/.golazo/publish.json
