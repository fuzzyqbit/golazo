# --- Video files (per operator: the only content we never track) ---
*.mp4
*.mov
*.mkv
*.webm

# --- Dependencies & build output ---
node_modules/
dist/
coverage/
.golazo/

# --- Tooling / agent scratch dirs ---
.superpowers/

# --- Secrets / operator-local config (NEVER commit) ---
# OAuth tokens are personal credentials; channels.yaml + .env hold the
# operator's real config. Fixture copies are whitelisted below.
*.token.json
channels.yaml
.env*
*.env

# --- Local junk & logs ---
.DS_Store
*.log
# npm puts its log + update-notifier cache here when HOME is stubbed to
# the repo root (see tests/fixtures/golazo/README.md — vitest / manual
# CLI smokes use HOME="$PWD"). Not a build artifact; safe to ignore.
.npm/

# Snapshot diff outputs are debug artifacts only — never committed
tests/snapshots/.diff/

# sqlite cache — derived from filesystem, regenerated on first scan
web/data/*.db
web/data/*.db-shm
web/data/*.db-wal

# --- Whitelisted committed fixtures (must survive the broad rules above) ---
# Integration-fixture binaries — see tests/fixtures/golazo/README.md and
# scripts/build-fixtures.sh. These `!` exceptions re-include version-controlled
# fixture assets the broad operator-side rules would otherwise ignore.
!tests/fixtures/golazo/channels.yaml
!tests/fixtures/golazo/leo/2026-05-13_vs_united_3-1/*.mp4
!tests/fixtures/golazo/*.token.json

# Committed Remotion font assets — see remotion/assets/fonts/README.md
!remotion/assets/fonts/*.ttf

# Committed Remotion music fixtures — see remotion/assets/music/README.md
!remotion/assets/music/*.mp3
!remotion/assets/music/index.json

# Committed web fixture tree — see web/tests/fixtures/golazo/README.md.
!web/tests/fixtures/golazo/channels.yaml
!web/tests/fixtures/golazo/**/*.mp4
!web/tests/fixtures/golazo/**/*.png
!web/tests/fixtures/golazo/**/.golazo/
!web/tests/fixtures/golazo/**/.golazo/manifest.json
!web/tests/fixtures/golazo/**/.golazo/episode.mp4
!web/tests/fixtures/golazo/**/.golazo/thumb.png
!web/tests/fixtures/golazo/**/.golazo/publish.json
